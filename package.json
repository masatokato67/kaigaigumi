{
  "name": "kaigaigumi",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "add-match": "tsx scripts/add-match.ts",
    "add-voice": "tsx scripts/add-local-voice.ts",
    "add-thread": "tsx scripts/add-x-thread.ts",
    "add-rating": "tsx scripts/add-media-rating.ts",
    "process-match": "tsx scripts/process-match-input.ts",
    "process-player-media": "tsx scripts/process-player-media.ts",
    "process-player-media-all": "for f in player-media-inputs/*.json; do p=$(basename \"$f\" .json); echo \"\\n========== $p ==========\"; tsx scripts/process-player-media.ts \"$p\"; done",
    "deploy-player-media": "npm run process-player-media-all && git add src/data/player-media/ player-media-inputs/ && git commit -m \"Update player media\" && git push origin main",
    "update-stats": "tsx scripts/update-stats.ts",
    "fetch-matches": "tsx scripts/fetch-matches-fotmob-html.ts",
    "fetch-matches-sofascore": "tsx scripts/fetch-matches-sofascore.ts",
    "fetch-matches-fotmob-legacy": "tsx scripts/fetch-matches.ts",
    "generate-content": "tsx scripts/generate-content.ts",
    "auto-update": "tsx scripts/fetch-matches-fotmob-html.ts && tsx scripts/generate-content.ts && tsx scripts/update-stats.ts",
    "manual-add": "tsx scripts/manual-add-match.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "cheerio": "^1.2.0",
    "dotenv": "^17.3.1",
    "next": "16.1.6",
    "node-fetch": "^2.7.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.7.0"
  },
  "devDependencies": {
    "@inquirer/prompts": "^8.2.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
